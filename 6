<?php
if (isset($_POST['num'])) {
    $num = $_POST['num'];

    echo "<h3>multiplication table $num (5-18)</h3>";

    for ($i = 5; $i <= 18; $i++) {
        $result = $num * $i;
        echo "$num x $i = $result <br>";
    }
}
?>

